---
import Card from './Card.astro';

const services = [
  {
    title: "Nuestro menú",
    description: "Descubre nuestra variedad de cafés y dulces artesanales.",
    image: "../assets/nuestro menu.jpg",
    icon: "🍽️"
  },
  {
    title: "Organiza tus meriendas",
    description: "Organiza tu merienda ideal con lo aprendido en nuestros talleres de preparación de cafés.",
    image: "../assets/Fotografía cafetería.jpg",
    icon: "🎉"
  },
  {
    title: "Cafe aroma para todos",
    description: "Ofrecemos experiencias mas alla de nuestras puertas, nuetro servicio de catering hará que te enamores.",
    image: "../assets/catering.jpg",
    icon: "👔"
  },
  {
    title: "Taller de preparación de café",
    description: "Aprende técnicas para realizar nuestra autentico café y aprende a preparar las mejores meriendas con aroma a ganador.",
    image: "../assets/taller de cafe.jpg",
    icon: "👨‍🍳"
  }
];
---

<section id="servicios" class="services">
  <div class="container">
    <div class="section-header">
      <h2>Nuestros Servicios</h2>
      <p>Descubre todas las experiencias que tenemos preparadas para ti</p>
    </div>

    <div class="cards-grid">
      {services.map((service) => (
        <Card 
          title={service.title}
          description={service.description}
          image={service.image}
          icon={service.icon}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background-color: var(--color-gray-light);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }

  .section-header h2 {
    margin-bottom: var(--spacing-md);
    color: var(--color-dark);
  }

  .section-header p {
    font-size: 1.1rem;
    color: #6b7280;
    max-width: 500px;
    margin: 0 auto;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
  }

  @media (max-width: 768px) {
    .section-header h2 {
      font-size: 1.75rem;
    }

    .cards-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-md);
    }
  }
</style>
